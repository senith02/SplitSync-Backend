NODE_ENV=development
PORT=5000
# Optional bind address for VPS/self-host (e.g. 0.0.0.0)
HOST=
# Optional public URL for logs/swagger server URL (e.g. https://mydomain.me)
PUBLIC_BASE_URL=
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/splitsync?retryWrites=true&w=majority
JWT_SECRET=replace_with_super_secure_secret
JWT_EXPIRES_IN=7d
